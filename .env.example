# ── Supabase ──────────────────────────────────────────────────────────────────
# Copia estos valores desde: Supabase Dashboard → Settings → API

# URL del proyecto (ej: https://abcdefghij.supabase.co)
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anon/public (es segura usarla en el frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.TU_CLAVE_ANON

# Conexión directa a PostgreSQL
# Supabase Dashboard → Settings → Database → Connection string → URI
# (elige "Transaction" pooler para Streamlit Cloud)
DATABASE_URL=postgresql://postgres.TU_PROYECTO:TU_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Configuración general ──────────────────────────────────────────────────────
SECRET_KEY=cambia-esto-en-produccion
SESSION_EXPIRY_DAYS=7
DEFAULT_COUNTRY=ES
DEFAULT_POSTAL_CODE=28001
ADMIN_EMAIL=tu@email.com
